# Copy this file to .env or export the variables in your shell before running Docker Compose.
# These values are safe local defaults for the production-like stack.

# ==================== Core deployment ====================
ZBLOG_POSTGRES_DB=zblog
ZBLOG_POSTGRES_USER=zblog
ZBLOG_POSTGRES_PASSWORD=zblog

ZBLOG_DATASOURCE_URL=jdbc:postgresql://postgres:5432/zblog
ZBLOG_DATASOURCE_USERNAME=zblog
ZBLOG_DATASOURCE_PASSWORD=zblog

ZBLOG_REDIS_HOST=redis
ZBLOG_REDIS_PORT=6379
ZBLOG_REDIS_PASSWORD=
ZBLOG_REDIS_TIMEOUT=2s

ZBLOG_RABBITMQ_HOST=rabbitmq
ZBLOG_RABBITMQ_PORT=5672
ZBLOG_RABBITMQ_USERNAME=zblog
ZBLOG_RABBITMQ_PASSWORD=zblog

ZBLOG_SEARCH_STRATEGY=db
ZBLOG_SEARCH_FALLBACK_TO_DB=true
ZBLOG_ELASTICSEARCH_URL=http://elasticsearch:9200
ZBLOG_ELASTICSEARCH_INDEX=zblog-articles

ZBLOG_ARTICLE_VIEW_DEDUP_SECONDS=10
ZBLOG_COLLECT_RATE_LIMIT_PER_MINUTE=120
ZBLOG_SITE_STATS_CACHE_SECONDS=60

ZBLOG_MQ_EXCHANGE=zblog.events
ZBLOG_MQ_ARTICLE_PUBLISHED_ROUTING_KEY=article.published
ZBLOG_MQ_ARTICLE_PUBLISHED_QUEUE=zblog.article.published
ZBLOG_MQ_SEARCH_INDEX_ROUTING_KEY=search.index
ZBLOG_MQ_SEARCH_INDEX_QUEUE=zblog.search.index

ZBLOG_MAIL_MODE=outbox
ZBLOG_MAIL_FROM=noreply@zblog.local
ZBLOG_MAIL_HOST=
ZBLOG_MAIL_PORT=25
ZBLOG_MAIL_USERNAME=
ZBLOG_MAIL_PASSWORD=

ZBLOG_RSS_ALLOW_PRIVATE_NETWORK=false
ZBLOG_PUBLIC_SITE_URL=http://localhost:3000
ZBLOG_MAX_FILE_SIZE=10MB
ZBLOG_MAX_REQUEST_SIZE=12MB
ZBLOG_JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ZBLOG_TOKEN_TTL_MINUTES=120
ZBLOG_ADMIN_USERNAME=admin
ZBLOG_ADMIN_PASSWORD=admin123456

NUXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NUXT_API_SERVER_URL=http://server:8080/api/v1
NUXT_PUBLIC_SITE_URL=http://localhost:3000
API_URL=http://localhost:8080/api/v1
